              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">WITH DedupOrders AS
(
    SELECT
        Transaction_ID,
        Customer_ID,
        Product_Code,
        [Date],
        [Year],
        [Month],
        [Time],
        Total_Purchases,
        Amount,
        Total_Amount,
        Feedback,
        Shipping_Method,
        Payment_Method,
        Order_Status,
        Ratings,
        ROW_NUMBER() OVER
        (
            PARTITION BY Transaction_ID
            ORDER BY [Date], [Time], Product_Code
        ) AS rn
    FROM dbo.StgRetailOrders
    WHERE [Date] IS NOT NULL
)
SELECT
    Transaction_ID,
    Customer_ID,
    Product_Code,
    [Date],
    [Year],
    [Month],
    [Time],
    Total_Purchases,
    Amount,
    Total_Amount,
    Feedback,
    Shipping_Method,
    Payment_Method,
    Order_Status,
    Ratings
FROM DedupOrders
WHERE rn = 1;</property>
