      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{4F400395-D7AF-45ED-959B-02D10BE694B0}"
          SQLTask:SqlStatementSource="UPDATE dbo.FactRetailSales&#xA;SET txn_process_time_hours = DATEDIFF(HOUR, accm_txn_create_time, accm_txn_complete_time)&#xA;WHERE accm_txn_complete_time IS NOT NULL&#xA;  AND txn_process_time_hours IS NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
